  flower: { id: number; name: string; description: string; price: number; imageUrl: string | null; country: string | null; category: string | null; inStock: boolean };
  onAddToCart: (id: number) => void;
  isLoading: boolean;
}) {
  return (
    <Card className="group overflow-hidden hover:shadow-lg transition-shadow duration-300 flex flex-col">
      <Link href={`/flowers/${flower.id}`}>
        <div className="aspect-square bg-muted overflow-hidden">
          {flower.imageUrl ? (
            <img
              src={flower.imageUrl}
              alt={flower.name}
              className="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              onError={(e) => {
                (e.target as HTMLImageElement).src = "https://images.unsplash.com/photo-1487530811015-780f2b26c9c0?w=400";
              }}
            />
          ) : (
            <div className="w-full h-full flex items-center justify-center">
              <Flower2 className="h-16 w-16 text-muted-foreground opacity-30" />
            </div>
          )}
        </div>
      </Link>
      <CardContent className="p-4 flex-1">
        <Link href={`/flowers/${flower.id}`}>
          <h3 className="font-semibold text-foreground hover:text-primary transition-colors line-clamp-1">
            {flower.name}
          </h3>
        </Link>
        <p className="text-sm text-muted-foreground mt-1 line-clamp-2">{flower.description}</p>
        <div className="flex items-center gap-2 mt-2 flex-wrap">
          {flower.country && (
            <span className="flex items-center gap-1 text-xs text-muted-foreground">
              <MapPin className="h-3 w-3" /> {flower.country}
            </span>
          )}
          {flower.category && (
            <Badge variant="secondary" className="text-xs">{flower.category}</Badge>
          )}
        </div>
      </CardContent>
      <CardFooter className="p-4 pt-0 flex items-center justify-between">
        <span className="text-lg font-bold text-primary">{flower.price.toFixed(0)} ₽</span>
        <Button size="sm" onClick={() => onAddToCart(flower.id)} disabled={isLoading} className="gap-1.5">
          <ShoppingCart className="h-4 w-4" />
          В корзину
        </Button>
      </CardFooter>
    </Card>
  );
}

export default function Home() {
  const [search, setSearch] = useState("");
  const [selectedCategory, setSelectedCategory] = useState<string | null>(null);
  const [selectedCountry, setSelectedCountry] = useState<string | null>(null);
  const queryClient = useQueryClient();

  const { data: userData } = useGetCurrentUser();
  const user = userData?.user ?? null;

  const params: Record<string, string> = {};
  if (selectedCategory) params.category = selectedCategory;
  if (selectedCountry) params.country = selectedCountry;

  const { data: flowers = [], isLoading: flowersLoading } = useListFlowers(params);
  const { data: featured = [] } = useGetFeaturedFlowers();
  const { data: categories = [] } = useGetCategories();
  const { data: countries = [] } = useGetCountries();

  const addToCart = useAddToCart({
    mutation: {
      onSuccess: () => {
        queryClient.invalidateQueries({ queryKey: getGetCartQueryKey() });
        toast.success("Добавлено в корзину");
      },
      onError: (err: any) => {
        const msg = err?.data?.error ?? "Ошибка при добавлении";
        if (msg.includes("авториз")) {
          toast.error("Войдите в аккаунт, чтобы добавить товар в корзину");
        } else {
          toast.error(msg);
        }
      },
    },
  });

  const handleAddToCart = (flowerId: number) => {
    if (!user) {
      toast.error("Войдите в аккаунт, чтобы добавить товар в корзину");
      return;
    }
    addToCart.mutate({ data: { flowerId, quantity: 1 } });
  };

  const filtered = flowers.filter((f) =>
    search ? f.name.toLowerCase().includes(search.toLowerCase()) : true
  );

  const resetFilters = () => {
    setSelectedCategory(null);
    setSelectedCountry(null);
    setSearch("");
  };

  const hasFilters = selectedCategory || selectedCountry || search;

  return (
    <div className="min-h-screen bg-background">
      {/* Hero */}
      <section className="bg-gradient-to-br from-primary/10 via-background to-accent/20 border-b border-border py-16 px-4">
        <div className="max-w-3xl mx-auto text-center">
          <div className="flex items-center justify-center gap-3 mb-4">
            <Flower2 className="h-10 w-10 text-primary" />
            <h1 className="text-5xl font-bold text-primary" style={{ fontFamily: "'Cormorant Garamond', serif" }}>
              FlowerWorld
            </h1>
          </div>
          <p className="text-xl text-muted-foreground mt-3" style={{ fontFamily: "'Cormorant Garamond', serif" }}>
            Международная доставка цветов — свежесть со всего мира у вас дома
          </p>
          <div className="relative mt-8 max-w-lg mx-auto">
            <Search className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground" />
            <Input
              placeholder="Поиск цветов..."
              value={search}
              onChange={(e) => setSearch(e.target.value)}
              className="pl-9 bg-card"
            />
          </div>
        </div>
      </section>

      <div className="max-w-6xl mx-auto px-4 py-10">
        {/* Featured */}
        {!hasFilters && featured.length > 0 && (
          <section className="mb-12">
            <div className="flex items-center gap-2 mb-6">
              <Star className="h-5 w-5 text-primary fill-primary" />
              <h2 className="text-2xl font-bold" style={{ fontFamily: "'Cormorant Garamond', serif" }}>
                Премиум выбор
              </h2>
            </div>
            <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
              {featured.slice(0, 4).map((f) => (
                <FlowerCard key={f.id} flower={f} onAddToCart={handleAddToCart} isLoading={addToCart.isPending} />
              ))}
            </div>
          </section>
        )}

        <div className="flex flex-col md:flex-row gap-6">
          {/* Sidebar filters */}
          <aside className="w-full md:w-52 shrink-0 space-y-5">
            <div>
              <h3 className="font-semibold mb-3 flex items-center gap-1.5 text-sm uppercase tracking-wide text-muted-foreground">
                <Tag className="h-3.5 w-3.5" /> Категории
              </h3>
              <div className="space-y-1">
                <button
                  onClick={() => setSelectedCategory(null)}
                  className={`w-full text-left px-3 py-1.5 rounded text-sm transition-colors ${!selectedCategory ? "bg-primary text-primary-foreground" : "hover:bg-muted"}`}
                >
                  Все категории
                </button>
                {categories.map((c) => (
                  <button
                    key={c.category}
                    onClick={() => setSelectedCategory(c.category)}
                    className={`w-full text-left px-3 py-1.5 rounded text-sm transition-colors flex justify-between items-center ${selectedCategory === c.category ? "bg-primary text-primary-foreground" : "hover:bg-muted"}`}
                  >
                    <span>{c.category}</span>
                    <Badge variant={selectedCategory === c.category ? "outline" : "secondary"} className="text-xs">
                      {c.count}
                    </Badge>
                  </button>
                ))}
              </div>
            </div>

            <div>
              <h3 className="font-semibold mb-3 flex items-center gap-1.5 text-sm uppercase tracking-wide text-muted-foreground">
                <MapPin className="h-3.5 w-3.5" /> Страна
              </h3>
              <div className="space-y-1">
                <button
                  onClick={() => setSelectedCountry(null)}
                  className={`w-full text-left px-3 py-1.5 rounded text-sm transition-colors ${!selectedCountry ? "bg-primary text-primary-foreground" : "hover:bg-muted"}`}
                >
                  Все страны
                </button>
                {countries.map((c) => (
                  <button
                    key={c.country}
                    onClick={() => setSelectedCountry(c.country)}
                    className={`w-full text-left px-3 py-1.5 rounded text-sm transition-colors flex justify-between items-center ${selectedCountry === c.country ? "bg-primary text-primary-foreground" : "hover:bg-muted"}`}
                  >
                    <span>{c.country}</span>
                    <Badge variant={selectedCountry === c.country ? "outline" : "secondary"} className="text-xs">
                      {c.count}
                    </Badge>
                  </button>
                ))}
              </div>
            </div>

            {hasFilters && (
              <Button variant="outline" size="sm" onClick={resetFilters} className="w-full">
                Сбросить фильтры
              </Button>
            )}
          </aside>

          {/* Flower grid */}
          <div className="flex-1">
            <div className="flex items-center justify-between mb-4">
              <h2 className="text-2xl font-bold" style={{ fontFamily: "'Cormorant Garamond', serif" }}>
                {selectedCategory ?? selectedCountry ?? "Все цветы"}
              </h2>
              <span className="text-sm text-muted-foreground">{filtered.length} товаров</span>
            </div>
            {flowersLoading ? (
              <div className="grid grid-cols-2 md:grid-cols-3 gap-4">
                {[...Array(6)].map((_, i) => (
                  <div key={i} className="h-72 rounded-lg bg-muted animate-pulse" />
                ))}
              </div>
            ) : filtered.length === 0 ? (
              <div className="text-center py-20 text-muted-foreground">
                <Flower2 className="h-16 w-16 mx-auto mb-4 opacity-20" />
