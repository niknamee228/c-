function JsonExportTab({ enabled }: { enabled: boolean }) {
  const queryClient = useQueryClient();
  const [copied, setCopied] = useState(false);

  const { data: exportData, isLoading, dataUpdatedAt } = useGetAdminExport({
    query: { enabled, staleTime: 0 } as any,
  });

  const jsonString = exportData
    ? JSON.stringify(exportData, null, 2)
    : null;

  const handleCopy = () => {
    if (!jsonString) return;
    navigator.clipboard.writeText(jsonString).then(() => {
      setCopied(true);
      setTimeout(() => setCopied(false), 2000);
      toast.success("JSON скопирован в буфер обмена");
    });
  };

  const handleDownload = () => {
    if (!jsonString) return;
    const blob = new Blob([jsonString], { type: "application/json" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = `flowerworld-export-${new Date().toISOString().slice(0, 10)}.json`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
    toast.success("Файл загружен");
  };

  const handleRefresh = () => {
    queryClient.invalidateQueries({ queryKey: getGetAdminExportQueryKey() });
  };

  return (
    <div className="space-y-4">
      {/* Header bar */}
      <Card>
        <CardContent className="p-4">
          <div className="flex items-center justify-between flex-wrap gap-3">
            <div className="flex items-center gap-3">
              <FileJson className="h-5 w-5 text-primary" />
              <div>
                <p className="font-semibold text-sm">Экспорт данных магазина</p>
                {dataUpdatedAt ? (
                  <p className="text-xs text-muted-foreground">
                    Сгенерировано: {new Date(dataUpdatedAt).toLocaleString("ru-RU")}
                  </p>
                ) : null}
              </div>
            </div>
            <div className="flex items-center gap-2">
              <Button variant="outline" size="sm" onClick={handleRefresh} className="gap-1.5">
                <RefreshCw className="h-3.5 w-3.5" />
                Обновить
              </Button>
              <Button variant="outline" size="sm" onClick={handleCopy} disabled={!jsonString} className="gap-1.5">
                {copied ? <Check className="h-3.5 w-3.5 text-green-600" /> : <Copy className="h-3.5 w-3.5" />}
                {copied ? "Скопировано" : "Копировать"}
              </Button>
              <Button size="sm" onClick={handleDownload} disabled={!jsonString} className="gap-1.5">
                <Download className="h-3.5 w-3.5" />
                Скачать .json
              </Button>
            </div>
          </div>

          {/* Meta summary badges */}
          {exportData && (
            <div className="flex flex-wrap gap-2 mt-4 pt-4 border-t border-border">
              <Badge variant="secondary" className="gap-1.5 text-xs py-1">
                <Users className="h-3 w-3" />
                {exportData.meta.totalUsers} пользователей
              </Badge>
              <Badge variant="secondary" className="gap-1.5 text-xs py-1">
                <Flower2 className="h-3 w-3" />
                {exportData.meta.totalFlowers} цветков
              </Badge>
              <Badge variant="secondary" className="gap-1.5 text-xs py-1">
                <Package className="h-3 w-3" />
                {exportData.meta.totalOrders} заказов
              </Badge>
              <Badge variant="secondary" className="gap-1.5 text-xs py-1">
                <TrendingUp className="h-3 w-3" />
                {exportData.meta.totalRevenue.toFixed(2)} ₽ выручка
              </Badge>
            </div>
          )}
        </CardContent>
      </Card>

      {/* JSON viewer */}
      <Card className="overflow-hidden">
        <CardHeader className="py-2.5 px-4 bg-muted/50 border-b border-border">
          <div className="flex items-center gap-2">
            <div className="flex gap-1.5">
              <div className="w-3 h-3 rounded-full bg-destructive/60" />
              <div className="w-3 h-3 rounded-full bg-yellow-400/80" />
              <div className="w-3 h-3 rounded-full bg-green-500/70" />
            </div>
