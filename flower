            ) : (
              <div className="grid grid-cols-2 md:grid-cols-3 gap-4">
                {filtered.map((f) => (
                  <FlowerCard key={f.id} flower={f} onAddToCart={handleAddToCart} isLoading={addToCart.isPending} />
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}


