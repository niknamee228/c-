  <script>
    // Статистика
    const statsData = [
      { icon: "👥", title: "Всего команд", value: "48" },
      { icon: "🔥", title: "Осталось в игре", value: "31" },
      { icon: "💥", title: "Выбыли", value: "17" },
      { icon: "✅", title: "Прошли 1 этап", value: "12" },
      { icon: "👤", title: "Всего участников", value: "214" },
      { icon: "🌍", title: "Городов представлено", value: "28" },
      { icon: "📊", title: "Средний размер команды", value: "4.5" },
      { icon: "⚡", title: "Активны сейчас", value: "89" }
    ];

    const slider = document.getElementById('statsSlider');
    const dotsContainer = document.getElementById('dotsContainer');

    function createCards() {
      if (!slider) return;
      slider.innerHTML = '';
      if (dotsContainer) dotsContainer.innerHTML = '';

      statsData.forEach((stat, index) => {
        const card = document.createElement('div');
        card.className = 'stat-card card-bg rounded-3xl p-6 sm:p-8 text-center flex flex-col items-center justify-center';
        card.style.minHeight = '220px';
        card.innerHTML = `
          <div class="text-5xl sm:text-6xl mb-4">${stat.icon}</div>
          <p class="text-gray-600 text-sm font-medium uppercase">${stat.title}</p>
          <p class="text-5xl sm:text-6xl font-bold mt-2 text-gray-800">${stat.value}</p>
        `;
        slider.appendChild(card);

        if (dotsContainer) {
          const dot = document.createElement('button');
          dot.className = `dot ${index === 0 ? 'active' : ''}`;
          dot.onclick = () => scrollToCard(index);
          dotsContainer.appendChild(dot);
        }
      });
      
      updateActiveDot();
      slider.addEventListener('scroll', updateActiveDot);
    }

    function updateActiveDot() {
      if (!slider || !dotsContainer) return;
      const cards = slider.querySelectorAll('.stat-card');
      if (cards.length === 0) return;
      
      const sliderRect = slider.getBoundingClientRect();
      const sliderCenter = sliderRect.left + sliderRect.width / 2;
      let closestIndex = 0;
      let closestDistance = Infinity;
      
      cards.forEach((card, index) => {
        const cardRect = card.getBoundingClientRect();
        const cardCenter = cardRect.left + cardRect.width / 2;
        const distance = Math.abs(sliderCenter - cardCenter);
        if (distance < closestDistance) {
          closestDistance = distance;
          closestIndex = index;
        }
      });
      
      const dots = dotsContainer.querySelectorAll('.dot');
      dots.forEach((dot, idx) => dot.classList.toggle('active', idx === closestIndex));
    }

    function scrollToCard(index) {
      if (!slider) return;
      const cards = slider.querySelectorAll('.stat-card');
      if (cards[index]) cards[index].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }

    window.scrollSlider = function(direction) {
      if (!slider) return;
      const cardWidth = slider.querySelector('.stat-card')?.offsetWidth || 300;
      const gap = 24;
      slider.scrollBy({ left: direction * (cardWidth + gap), behavior: 'smooth' });
    };

    // Регистрация
    function registerTeam(event) {
      event.preventDefault();
      const name = document.getElementById('teamName').value;
      const captain = document.getElementById('captainName').value;
      const phone = document.getElementById('phone').value;
      const email = document.getElementById('email').value;
      const caseSelected = document.getElementById('caseSelect').value;

      if (name && captain && phone && email) {
        document.getElementById('teamInfo').innerHTML = `
          <p class="text-lg font-medium">${name}</p>
          <p class="text-blue-600 mt-2">✅ Зарегистрирована</p>
          <p class="text-sm text-gray-500">Капитан: ${captain}</p>
          <p class="text-sm text-gray-500">📱 ${phone}</p>
          ${caseSelected ? `<p class="text-sm text-blue-600 mt-2">📋 Кейс: ${document.getElementById('caseSelect').selectedOptions[0].text}</p>` : ''}
        `;
        alert(`✅ Команда "${name}" зарегистрирована!`);
        document.getElementById('regForm').reset();
      }
    }

    function viewCases() {
      alert('📋 Доступные кейсы:\n\n1. ИИ для автоматизации\n2. Веб-платформа\n3. Кибербезопасность\n4. Мобильное приложение\n\nВыберите кейс в форме регистрации.');
    }

    function subscribe(event) {
      event.preventDefault();
      const email = document.getElementById('subscribeEmail').value;
      if (email) {
        alert(`✅ Подписка оформлена на ${email}`);
        document.getElementById('subscribeEmail').value = '';
      }
    }

    window.toggleFaq = (btn) => {
      const item = btn.parentElement;
      const icon = btn.querySelector('i');
      item.classList.toggle('active');
      icon.style.transform = item.classList.contains('active') ? 'rotate(180deg)' : 'rotate(0deg)';
    };

    window.openTicketModal = () => document.getElementById('ticketModal').classList.remove('hidden');
    window.closeTicketModal = () => document.getElementById('ticketModal').classList.add('hidden');
    window.submitTicket = () => {
      const subject = document.getElementById('ticketSubject').value;
      if (subject) {
        alert(`✅ Тикет создан: ${subject}`);
        closeTicketModal();
      }
    };

    window.openChat = () => {
      document.getElementById('chatWidget').classList.remove('hidden');
      document.getElementById('chatButton').classList.add('hidden');
    };
    window.closeChat = () => {
      document.getElementById('chatWidget').classList.add('hidden');
      document.getElementById('chatButton').classList.remove('hidden');
    };
    window.sendChatMessage = () => {
      const input = document.getElementById('chatInput');
      if (input.value.trim()) {
        document.getElementById('chatMessages').innerHTML += `
          <div class="flex gap-2 justify-end">
            <div class="bg-blue-600 text-white rounded-xl p-3 text-sm">${input.value}</div>
          </div>`;
        input.value = '';
      }
    };

    // Админ-панель
    window.openAdminPanel = () => document.getElementById('adminPanel').classList.remove('hidden');
    window.closeAdminPanel = () => document.getElementById('adminPanel').classList.add('hidden');
    window.showAdminSection = (section) => {
      document.querySelectorAll('.admin-section').forEach(el => el.classList.add('hidden'));
      document.getElementById('admin' + section.charAt(0).toUpperCase() + section.slice(1)).classList.remove('hidden');
    };
    window.sendTicketReply = (id) => {
      const reply = document.getElementById('ticketReply' + id).value;
      if (reply) alert('✅ Ответ отправлен!');
    };
    window.changeTicketStatus = (id, status) => {
      alert(`✅ Статус: ${status === 'resolved' ? 'Решено' : 'В обработке'}`);
    };
    window.sendAdminMessage = () => {
      const input = document.getElementById('adminChatInput');
      if (input.value.trim()) {
        document.getElementById('adminChatMessages').innerHTML += `
          <div class="flex gap-2 justify-end mb-3">
            <div class="bg-blue-600 text-white rounded-xl p-3 text-sm">${input.value}</div>
          </div>`;
        input.value = '';
      }
    };
    window.addFaqItem = () => {
      document.getElementById('adminFaqList').innerHTML += `
        <div class="bg-gray-50 rounded-xl p-4 border">
          <input class="w-full border rounded-lg px-3 py-2 mb-2 bg-white" placeholder="Вопрос">
          <textarea class="w-full border rounded-lg px-3 py-2 bg-white" rows="2" placeholder="Ответ"></textarea>
          <button onclick="this.parentElement.remove()" class="text-red-500 text-sm mt-2">Удалить</button>
        </div>`;
    };
    window.testTelegramConnection = () => alert('✅ Telegram подключен!');

    window.registerTeam = registerTeam;
    window.viewCases = viewCases;
    window.subscribe = subscribe;

    createCards();
  </script>
