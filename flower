import { useRoute, useLocation, Link } from "wouter";
import {
  useGetFlower,
  useAddToCart,
  useGetCurrentUser,
  getGetCartQueryKey,
} from "@workspace/api-client-react";
import { useQueryClient } from "@tanstack/react-query";
import { toast } from "sonner";
import { ShoppingCart, MapPin, Tag, ArrowLeft, Flower2 } from "lucide-react";
import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";

export default function FlowerDetail() {
  const [, params] = useRoute("/flowers/:id");
  const [, navigate] = useLocation();
  const id = Number(params?.id);
  const queryClient = useQueryClient();

  const { data: userData } = useGetCurrentUser();
  const user = userData?.user ?? null;
  const { data: flower, isLoading, error } = useGetFlower(id);

  const addToCart = useAddToCart({
    mutation: {
      onSuccess: () => {
        queryClient.invalidateQueries({ queryKey: getGetCartQueryKey() });
        toast.success("Добавлено в корзину");
      },
      onError: (err: any) => {
        toast.error(err?.data?.error ?? "Ошибка");
      },
    },
  });

  if (isLoading) {
    return (
      <div className="max-w-4xl mx-auto px-4 py-10">
        <div className="grid md:grid-cols-2 gap-8">
          <div className="aspect-square bg-muted animate-pulse rounded-xl" />
          <div className="space-y-4">
            <div className="h-8 bg-muted animate-pulse rounded w-3/4" />
            <div className="h-4 bg-muted animate-pulse rounded w-1/2" />
            <div className="h-20 bg-muted animate-pulse rounded" />
          </div>
        </div>
      </div>
    );
  }

  if (error || !flower) {
    return (
      <div className="max-w-4xl mx-auto px-4 py-20 text-center">
        <Flower2 className="h-16 w-16 mx-auto mb-4 text-muted-foreground opacity-30" />
        <p className="text-xl text-muted-foreground">Цветок не найден</p>
        <Link href="/">
          <Button className="mt-4">На главную</Button>
        </Link>
      </div>
    );
  }

  return (
    <div className="max-w-4xl mx-auto px-4 py-10">
      <Button
        variant="ghost"
        onClick={() => navigate("/")}
        className="mb-6 gap-2 -ml-2"
      >
        <ArrowLeft className="h-4 w-4" />
        Назад к каталогу
      </Button>

      <div className="grid md:grid-cols-2 gap-10">
        <div className="aspect-square overflow-hidden rounded-xl bg-muted shadow-lg">
          {flower.imageUrl ? (
            <img
              src={flower.imageUrl}
              alt={flower.name}
              className="w-full h-full object-cover"
              onError={(e) => {
                (e.target as HTMLImageElement).src = "https://images.unsplash.com/photo-1487530811015-780f2b26c9c0?w=600";
              }}
            />
          ) : (
            <div className="w-full h-full flex items-center justify-center">
              <Flower2 className="h-24 w-24 text-muted-foreground opacity-30" />
            </div>
          )}
        </div>

        <div className="space-y-5">
          <div>
            <h1 className="text-4xl font-bold text-foreground" style={{ fontFamily: "'Cormorant Garamond', serif" }}>
              {flower.name}
            </h1>
            <div className="flex items-center gap-3 mt-3 flex-wrap">
              {flower.country && (
                <span className="flex items-center gap-1.5 text-sm text-muted-foreground">
                  <MapPin className="h-4 w-4" />
                  {flower.country}
                </span>
              )}
              {flower.category && (
                <Badge variant="secondary" className="flex items-center gap-1">
                  <Tag className="h-3 w-3" />
                  {flower.category}
                </Badge>
              )}
              <Badge variant={flower.inStock ? "default" : "destructive"}>
                {flower.inStock ? "В наличии" : "Нет в наличии"}
              </Badge>
            </div>
          </div>

          <p className="text-muted-foreground leading-relaxed">{flower.description}</p>

          <div className="border-t border-border pt-5">
            <p className="text-4xl font-bold text-primary">{flower.price.toFixed(2)} ₽</p>
            <p className="text-sm text-muted-foreground mt-1">за штуку</p>
          </div>

          <Button
            size="lg"
            className="w-full gap-2"
            disabled={!flower.inStock || addToCart.isPending}
            onClick={() => {
              if (!user) {
                toast.error("Войдите в аккаунт, чтобы добавить товар в корзину");
                return;
              }
              addToCart.mutate({ data: { flowerId: flower.id, quantity: 1 } });
            }}
          >
            <ShoppingCart className="h-5 w-5" />
            {addToCart.isPending ? "Добавляем..." : flower.inStock ? "Добавить в корзину" : "Нет в наличии"}
          </Button>

          {!user && (
            <p className="text-sm text-muted-foreground text-center">
              <Link href="/login" className="text-primary hover:underline">Войдите</Link>, чтобы сделать заказ
            </p>
          )}
        </div>
      </div>
    </div>
  );
}


